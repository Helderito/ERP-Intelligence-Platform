###############################################################################
# ERP Intelligence Platform
# Git Attributes
###############################################################################

###############################################################################
# Auto-detect text files and normalize line endings
###############################################################################

* text=auto

###############################################################################
# Source code files
###############################################################################

*.cs        text eol=lf
*.csproj    text eol=lf
*.sln       text eol=crlf

*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf

*.css       text eol=lf
*.scss      text eol=lf
*.html      text eol=lf

*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.xml       text eol=lf

###############################################################################
# Documentation
###############################################################################

*.md        text eol=lf
*.txt       text eol=lf

###############################################################################
# SQL and database scripts
###############################################################################

*.sql       text eol=lf

###############################################################################
# Shell scripts
###############################################################################

*.sh        text eol=lf
*.ps1       text eol=crlf
*.bat       text eol=crlf
*.cmd       text eol=crlf

###############################################################################
# Docker and infrastructure
###############################################################################

Dockerfile  text eol=lf
*.dockerfile text eol=lf
docker-compose*.yml text eol=lf

*.tf        text eol=lf
*.bicep     text eol=lf

###############################################################################
# Images and binary assets
###############################################################################

*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       text eol=lf

###############################################################################
# Documents and office files
###############################################################################

*.pdf       binary
*.docx      binary
*.xlsx      binary
*.pptx      binary

###############################################################################
# Power BI
###############################################################################

*.pbix      binary
*.pbit      binary

###############################################################################
# Archives
###############################################################################

*.zip       binary
*.rar       binary
*.7z        binary
*.tar       binary
*.gz        binary

###############################################################################
# Fonts
###############################################################################

*.ttf       binary
*.otf       binary
*.woff      binary
*.woff2     binary